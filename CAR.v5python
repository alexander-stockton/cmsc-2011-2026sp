{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nWheel_L = Motor(Ports.PORT11, GearSetting.RATIO_36_1, False)\nWheel_R = Motor(Ports.PORT12, GearSetting.RATIO_36_1, False)\ncontroller_1 = Controller(PRIMARY)\nWheel_TURN = Motor(Ports.PORT13, GearSetting.RATIO_18_1, False)\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n\n\n# define variables used for controlling motors based on controller inputs\ncontroller_1_up_down_buttons_control_motors_stopped = True\ncontroller_1_x_b_buttons_control_motors_stopped = True\n\n# define a task that will handle monitoring inputs from controller_1\ndef rc_auto_loop_function_controller_1():\n    global controller_1_up_down_buttons_control_motors_stopped, controller_1_x_b_buttons_control_motors_stopped, remote_control_code_enabled\n    # process the controller input every 20 milliseconds\n    # update the motors based on the input values\n    while True:\n        if remote_control_code_enabled:\n            # check the buttonUp/buttonDown status\n            # to control Wheel_L\n            if controller_1.buttonUp.pressing():\n                Wheel_L.spin(FORWARD)\n                controller_1_up_down_buttons_control_motors_stopped = False\n            elif controller_1.buttonDown.pressing():\n                Wheel_L.spin(REVERSE)\n                controller_1_up_down_buttons_control_motors_stopped = False\n            elif not controller_1_up_down_buttons_control_motors_stopped:\n                Wheel_L.stop()\n                # set the toggle so that we don't constantly tell the motor to stop when\n                # the buttons are released\n                controller_1_up_down_buttons_control_motors_stopped = True\n            # check the buttonX/buttonB status\n            # to control Wheel_R\n            if controller_1.buttonX.pressing():\n                Wheel_R.spin(REVERSE)\n                controller_1_x_b_buttons_control_motors_stopped = False\n            elif controller_1.buttonB.pressing():\n                Wheel_R.spin(FORWARD)\n                controller_1_x_b_buttons_control_motors_stopped = False\n            elif not controller_1_x_b_buttons_control_motors_stopped:\n                Wheel_R.stop()\n                # set the toggle so that we don't constantly tell the motor to stop when\n                # the buttons are released\n                controller_1_x_b_buttons_control_motors_stopped = True\n        # wait before repeating the process\n        wait(20, MSEC)\n\n# define variable for remote controller enable/disable\nremote_control_code_enabled = True\n\nrc_auto_loop_thread_controller_1 = Thread(rc_auto_loop_function_controller_1)\n\n#endregion VEXcode Generated Robot Configuration\n\nscreen_precision = 0\nconsole_precision = 0\ncontroller_1_precision = 0\nmyVariable = 0\n\ndef when_started1():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    # INIT\n    Wheel_L.set_max_torque(100, PERCENT)\n    Wheel_L.set_stopping(COAST)\n    Wheel_R.set_max_torque(100, PERCENT)\n    Wheel_R.set_stopping(COAST)\n    Wheel_TURN.set_max_torque(100, PERCENT)\n    Wheel_TURN.set_stopping(COAST)\n    while True:\n        wait(2, SECONDS)\n        controller_1.screen.clear_row(1)\n        controller_1.screen.set_cursor(controller_1.screen.row(), 1)\n        controller_1.screen.print(brain.battery.capacity(), precision=controller_1_precision)\n        wait(5, MSEC)\n\ndef controller_1buttonUp_pressed_callback_0():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_L.set_velocity(100, PERCENT)\n\ndef controller_1buttonX_pressed_callback_0():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_R.set_velocity(100, PERCENT)\n\ndef controller_1buttonUp_released_callback_0():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_L.stop()\n\ndef controller_1buttonX_released_callback_0():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_R.stop()\n\ndef controller_1buttonL1_pressed_callback_0():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_TURN.set_velocity(100, PERCENT)\n    Wheel_TURN.spin(FORWARD)\n\ndef controller_1buttonR1_pressed_callback_0():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_TURN.set_velocity(100, PERCENT)\n    Wheel_TURN.spin(REVERSE)\n\ndef controller_1buttonL1_released_callback_0():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_TURN.stop()\n\ndef controller_1buttonR1_released_callback_0():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_TURN.stop()\n\ndef controller_1buttonDown_pressed_callback_0():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_L.set_velocity(100, PERCENT)\n\ndef controller_1buttonB_pressed_callback_0():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_R.set_velocity(100, PERCENT)\n\ndef controller_1buttonDown_pressed_callback_1():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_L.stop()\n\ndef controller_1buttonB_pressed_callback_1():\n    global myVariable, screen_precision, console_precision, controller_1_precision\n    Wheel_R.stop()\n\n# system event handlers\ncontroller_1.buttonUp.pressed(controller_1buttonUp_pressed_callback_0)\ncontroller_1.buttonX.pressed(controller_1buttonX_pressed_callback_0)\ncontroller_1.buttonUp.released(controller_1buttonUp_released_callback_0)\ncontroller_1.buttonX.released(controller_1buttonX_released_callback_0)\ncontroller_1.buttonL1.pressed(controller_1buttonL1_pressed_callback_0)\ncontroller_1.buttonR1.pressed(controller_1buttonR1_pressed_callback_0)\ncontroller_1.buttonL1.released(controller_1buttonL1_released_callback_0)\ncontroller_1.buttonR1.released(controller_1buttonR1_released_callback_0)\ncontroller_1.buttonDown.pressed(controller_1buttonDown_pressed_callback_0)\ncontroller_1.buttonDown.pressed(controller_1buttonDown_pressed_callback_1)\ncontroller_1.buttonB.pressed(controller_1buttonB_pressed_callback_0)\ncontroller_1.buttonB.pressed(controller_1buttonB_pressed_callback_1)\n# add 15ms delay to make sure events are registered correctly.\nwait(15, MSEC)\n\nwhen_started1()\n","textLanguage":"python","robotConfig":[{"port":[11],"name":"Wheel_L","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio36_1"},"triportSourcePort":22},{"port":[12],"name":"Wheel_R","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio36_1"},"triportSourcePort":22},{"port":[],"name":"controller_1","customName":false,"deviceType":"Controller","deviceClass":"controller","setting":{"left":"","leftDir":"false","right":"","rightDir":"false","upDown":"Wheel_L","upDownDir":"false","xB":"Wheel_R","xBDir":"true","drive":"none","id":"primary"},"triportSourcePort":22},{"port":[13],"name":"Wheel_TURN","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse","gear":"ratio18_1"},"triportSourcePort":22}],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.65.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}